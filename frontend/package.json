{
  "name": "splat-replay-frontend",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pretest:e2e": "node ./scripts/ensure-e2e-assets.js",
    "test": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run",
    "test:coverage": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --coverage",
    "test:logic": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --config vitest.logic.config.ts",
    "test:component": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --config vitest.component.config.ts",
    "test:integration": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "test:unit": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run",
    "test:e2e": "playwright test",
    "check": "svelte-check --tsconfig ./tsconfig.json --threshold warning",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .ts,.svelte",
    "lint:fix": "eslint . --ext .ts,.svelte --fix",
    "type-check": "tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run type-check && npm run check",
    "generate:types": "openapi-typescript src/generated/openapi.json -o src/generated/api.d.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^4.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.1",
    "happy-dom": "^20.8.4",
    "openapi-typescript": "^7.4.4",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^4.2.0",
    "svelte-check": "^3.6.0",
    "svelte-eslint-parser": "^1.4.1",
    "tslib": "^2.8.0",
    "typescript": "^5.7.2",
    "vite": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "lucide-svelte": "^0.545.0"
  }
}
